# ===========================================
# PrepLoop Configuration
# ===========================================

# Required — Gemini API Key for question generation & grading
GEMINI_API_KEY=your-gemini-api-key-here

# Required — Password to access the dashboard (single-user auth)
APP_PASSWORD=your-dashboard-password

# Optional — Path to the vault directory (defaults to ./vault)
# VAULT_PATH=./vault

# Optional — Secret token to authorize the /api/generate cron endpoint
# CRON_SECRET=your-secure-cron-token

# Optional — Discord or Slack webhook URL for daily notifications
# WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional — Secret used to sign session cookies (auto-generated if not set)
# AUTH_SECRET=a-random-32-char-string
