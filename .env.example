GEMINI_API_KEY=your-existing-gemini-key
CRON_SECRET=preploop-cron-secret

# Firebase Server (Admin SDK)
FIREBASE_PROJECT_ID=preploop-XXXXX
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@preploop-XXXXX.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Client (Web SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=preploop-XXXXX.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=preploop-XXXXX

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-channel-id/your-webhook-token